<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0"
            prefWidth="950.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.universidad.controller.VistaPrincipalController">

    <children>

        <Label layoutX="240.0"
               layoutY="20.0"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"
               text="🏥 Sistema de Control de Emergencias"/>

        <Label layoutX="30.0"
               layoutY="80.0"
               text="Nombre Completo:"/>

        <TextField fx:id="txtNombre"
                   layoutX="150.0"
                   layoutY="75.0"
                   prefWidth="250.0"/>

        <Label layoutX="30.0"
               layoutY="120.0"
               text="Edad:"/>

        <TextField fx:id="txtEdad"
                   layoutX="150.0"
                   layoutY="115.0"
                   prefWidth="100.0"/>

        <Label layoutX="30.0"
               layoutY="160.0"
               text="DPI:"/>

        <TextField fx:id="txtDpi"
                   layoutX="150.0"
                   layoutY="155.0"
                   prefWidth="250.0"/>

        <Label layoutX="30.0"
               layoutY="200.0"
               text="Síntomas:"/>

        <TextArea fx:id="txtSintomas"
                  layoutX="150.0"
                  layoutY="195.0"
                  prefWidth="300.0"
                  prefHeight="120.0"/>

        <Label layoutX="30.0"
               layoutY="340.0"
               text="Prioridad:"/>

        <ComboBox fx:id="cmbPrioridad"
                  layoutX="150.0"
                  layoutY="335.0"
                  prefWidth="150.0"/>

        <Button layoutX="150.0"
                layoutY="390.0"
                prefWidth="170.0"
                text="Registrar Paciente"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"
                onAction="#registrarPaciente"/>

        <Button layoutX="500.0"
                layoutY="490.0"
                prefWidth="150.0"
                text="Actualizar Lista"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"
                onAction="#actualizarLista"/>

        <Button layoutX="680.0"
                layoutY="490.0"
                prefWidth="170.0"
                text="Atender Siguiente"
                style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-weight: bold;"
                onAction="#atenderSiguiente"/>

        <Label layoutX="520.0"
               layoutY="45.0"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"
               text="Pacientes en Espera"/>

        <TableView fx:id="tablaPacientes"
                   layoutX="450.0"
                   layoutY="70.0"
                   prefWidth="430.0"
                   prefHeight="400.0">

            <columns>

                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="50.0"/>

                <TableColumn fx:id="colNombre"
                             text="Nombre"
                             prefWidth="220.0"/>

                <TableColumn fx:id="colPrioridad"
                             text="Prioridad"
                             prefWidth="150.0"/>

            </columns>

        </TableView>

    </children>

</AnchorPane>